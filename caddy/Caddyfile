{
    # Contact email used for ACME account registration (Let's Encrypt).
    email {$ACME_EMAIL:admin@example.com}

    # Supports staging CA for dry-runs:
    # https://acme-staging-v02.api.letsencrypt.org/directory
    acme_ca {$ACME_CA:https://acme-v02.api.letsencrypt.org/directory}
}
# Homelab Dashboard — Caddy Reverse Proxy Configuration

# Examples:
# - SITE_ADDRESS=192.168.56.10 (local IP, HTTPS with Caddy local CA)
# - SITE_ADDRESS=http://192.168.56.10 (local IP, HTTP only)
# - SITE_ADDRESS=home.example.com (public DNS, automatic HTTPS)
{$SITE_ADDRESS:localhost,127.0.0.1,192.168.56.10} {
    # Forward API requests to backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Forward WebSocket requests to backend
    handle /ws/* {
        reverse_proxy backend:8000
    }

    # Forward everything else to frontend React SPA
    handle {
        reverse_proxy frontend:3000
    }

    # Enable compression
    encode gzip zstd
}

import /etc/caddy/marketplace_apps.caddy

# The Admin API is available internally on port 2019
# We will use this in Phase 4 to dynamically add routes for marketplace apps
