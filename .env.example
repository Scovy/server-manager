# Root environment variables used by docker-compose for Caddy TLS.
# Copy to .env in project root and adjust values.

# Caddy site address.
# - Public HTTPS: home.example.com
# - Local HTTPS (IP, Caddy local CA): 192.168.56.10
# - Local HTTP (explicitly disable HTTPS): http://192.168.56.10
SITE_ADDRESS=http://192.168.56.10

# Public DNS name used by setup metadata and backend public URL.
DOMAIN=192.168.56.10

# Email used for Let's Encrypt account and expiry notices.
ACME_EMAIL=admin@example.com

# Use Let's Encrypt production by default.
# For staging tests (no trusted certs), use:
# https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
